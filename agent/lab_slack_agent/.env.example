# ─────────────────────────────────────────────
# Slack credentials
# ─────────────────────────────────────────────
SLACK_BOT_TOKEN=xoxb-your-bot-token-here
SLACK_APP_TOKEN=xapp-your-app-token-here
SLACK_SIGNING_SECRET=your-signing-secret-here

# ─────────────────────────────────────────────
# User / bot IDs
# Get these from Slack's API or your workspace admin
# ─────────────────────────────────────────────
ROBOT_BOT_USER_ID=U0ROBOTIDHERE
HUMAN_USER_ID=U0HUMANIDHERE

# ─────────────────────────────────────────────
# LLM provider — choose "openai" or "anthropic"
# ─────────────────────────────────────────────
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o

OPENAI_API_KEY=sk-your-openai-key-here
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# ─────────────────────────────────────────────
# Data root — base directory where experiment
# data files are stored
# ─────────────────────────────────────────────
DATA_ROOT=/path/to/your/experiment/data
